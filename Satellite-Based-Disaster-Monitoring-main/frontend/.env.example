# Frontend API base URL.
#
# Development (npm run dev):
#   Leave empty — Vite proxies /api → http://127.0.0.1:8000 automatically.
#
# Production (backend serves built frontend on same port):
#   Leave empty — requests use same origin.
#
# Remote backend only (skip proxy, point directly at API):
# VITE_API_URL=http://192.168.1.10:8000
VITE_API_URL=
